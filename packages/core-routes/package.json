{
  "name": "@smm/core-routes",
  "version": "1.4.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "description": "Framework-agnostic HTTP route handlers for SMM",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "build": "bun build src/index.ts --outfile dist/core-routes.js --target node --format esm",
    "build:cjs": "bun build src/index.ts --outfile dist/core-routes.cjs --target node --format cjs",
    "build:ohos": "bun build src/index.ts --outfile ../../apps/ohos/web_engine/src/main/resources/resfile/resources/app/core-routes.js --target node --format cjs --minify"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.11",
    "@assistant-ui/react-ai-sdk": "^1.3.7",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@smm/core": "workspace:*",
    "ai": "^6.0.36",
    "socket.io": "^4.8.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
