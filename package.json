{
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all2 --parallel dev:ui dev:cli",
    "dev:ui": "pnpm --filter ui dev",
    "dev:cli": "cross-env SMM_AUTH_ENABLED=true SMM_AUTH_TOKEN=ChangeMe123 pnpm --filter cli dev",
    "dev:electron": "cd apps/electron && pnpm run dev",
    "build": "pnpm run build:cli && pnpm run build:ui",
    "build:cli": "cd apps/cli && pnpm run build",
    "build:ui": "cd apps/ui && pnpm run build",
    "build:electron": "pnpm --filter core typecheck && pnpm --filter cli build && pnpm --filter ui build && pnpm --filter electron build",
    "build:core": "cd packages/core && pnpm run typecheck",
    "build:docker": "docker buildx build --progress=plain -f apps/docker/Dockerfile -t smm:latest .",
    "build:docker:pkgs": "pnpm --filter \"docker...\" run build",
    "build:e2e": "docker build -t smm-e2e:test -f apps/e2e/Dockerfile .",
    "test": "pnpm -r test",
    "test:core": "cd packages/core && pnpm test",
    "test:core-routes": "cd packages/core-routes && pnpm test",
    "test:electron-common": "cd packages/electron-common && pnpm test",
    "test:cli": "cd apps/cli && pnpm test",
    "test:ui": "cd apps/ui && pnpm test",
    "test:e2e": "cd apps/e2e && pnpm run test",
    "e2e:ai": "bun ci/run-e2e-test.ts --spec \"./test/specs/ai/*.e2e.ts\"",
    "e2e:config": "bun ci/run-e2e-test.ts --spec \"./test/specs/config/*.e2e.ts\"",
    "e2e:mcp": "bun ci/run-e2e-test.ts --spec \"./test/specs/mcp/*.e2e.ts\"",
    "e2e:media-folder-initialization": "bun ci/run-e2e-test.ts --spec \"./test/specs/media-folder-initialization/*.e2e.ts\"",
    "e2e:movie": "bun ci/run-e2e-test.ts --spec \"./test/specs/movie/*.e2e.ts\"",
    "e2e:music": "bun ci/run-e2e-test.ts --spec \"./test/specs/music/*.e2e.ts\"",
    "e2e:other": "bun ci/run-e2e-test.ts --spec \"./test/specs/other/*.e2e.ts\"",
    "e2e:transcribe": "bun ci/run-e2e-test.ts --spec \"./test/specs/transcribe/*.e2e.ts\"",
    "e2e:tv": "bun ci/run-e2e-test.ts --spec \"./test/specs/tv/*.e2e.ts\"",
    "e2e:tvdb": "bun ci/run-e2e-test.ts --spec \"./test/specs/tvdb/*.e2e.ts\"",
    "typecheck": "pnpm run typecheck:core && pnpm run typecheck:core-routes && pnpm run typecheck:electron-common && pnpm run typecheck:cli && pnpm run typecheck:ui && pnpm run typecheck:e2e && pnpm run typecheck:electron && pnpm run typecheck:ohos-main",
    "typecheck:core": "cd packages/core && pnpm run typecheck",
    "typecheck:core-routes": "cd packages/core-routes && pnpm run typecheck",
    "typecheck:electron-common": "cd packages/electron-common && pnpm run typecheck",
    "typecheck:cli": "cd apps/cli && pnpm run typecheck",
    "typecheck:ui": "cd apps/ui && pnpm run typecheck",
    "typecheck:e2e": "cd apps/e2e && pnpm run typecheck",
    "typecheck:electron": "cd apps/electron && pnpm run typecheck",
    "typecheck:ohos-main": "pnpm --filter @smm/ohos-electron-main typecheck",
    "ci": "pnpm run build && pnpm run test && pnpm run typecheck",
    "ci:cli": "cd apps/cli && pnpm run test && pnpm run typecheck",
    "build:ohos": "bash ./ci/build-ohos.sh",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm i && pnpm run build:cli",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "npm-run-all2": "^8.0.4"
  }
}
